ORG 2050H ; data area
DB 05H, 05H, 0F0H, 15H, 0E5H, 0AH ;05, 05, -16, 21, -27, 10 
LXI H, 2050H ; HL = 2050H
MOV B, M ; B = N (number of elements)
INX H ; HL = 2051H (start of array)
MVI C, 00H ; C = sum = 0 

NEXT:
MOV A, M ; Get array element
MOV D, A ; Copy it to D for checking sign
ANI 80H ; Mask bit 7 (MSB)
JZ SKIP ; If 0 → positive → skip addition 
        ; Negative number → add to sum
MOV A, C ; A = current sum
ADD D ; A = A + negative number (2’s complement addition)
MOV C, A ; Save sum back to C 

SKIP:
INX H ; Next element
DCR B ; Decrement counter
JNZ NEXT ; Repeat for all elements ; Store final sum
LXI H, 2052H
MOV M, C 
HLT
